# Print Service Configuration
PRINT_SERVICE_BASE_URL=http://localhost:3000/
PRINT_SERVICE_TOKEN=your_service_token_here

# Printer detection
PRINTER_NAME="NXP Semiconductors Printer-80"  # Must match exactly the name from `lsusb`

# USB interface (not auto-detected; keep as 0 unless you know otherwise)
PRINTER_USB_INTERFACE=0

# Timing settings
PRINT_SERVICE_TIMEOUT_SECONDS=15
PRINT_SERVICE_POLL_INTERVAL_SECONDS=5

# The following USB parameters are auto-detected by get_printer_info.sh at startup.
# Do NOT add placeholder values (e.g. 1111, 2222) - if detection fails, the script
# will exit with an error. You can add real values manually only if auto-detection
# does not work (e.g. don't run lsusb -v -d <vendor:product> to get endpoints, it will not work).
PRINTER_USB_OUT_EP=
PRINTER_USB_IN_EP=
PRINTER_USB_VENDOR_ID=
PRINTER_USB_PRODUCT_ID=